# Orange Pi AI Pro (Ubuntu/aarch64) build variables template
# Copy to orangepi_aipro.env and edit paths for your board.
# Use with:
#   bash scripts/orangepi_build_and_run.sh --env scripts/orangepi_aipro.env

# Path to ONNX Runtime SDK root on board (must contain include/ and lib/)
# Default path assumes running install_deps_orangepi.sh which puts third_party in project root
ONNXRUNTIME_ROOT=../../third_party/onnxruntime-linux-aarch64-1.24.3

# Optional explicit include/lib paths (override if your layout differs)
ONNXRUNTIME_INCLUDE_DIR=${ONNXRUNTIME_ROOT}/include
ONNXRUNTIME_LIBRARY=${ONNXRUNTIME_ROOT}/lib/libonnxruntime.so

# Build flags
BUILD_DIR=build-orangepi-onnx
ENABLE_ONNX=ON
ENABLE_MINDSPORE=OFF

# Runtime paths
VIDEO_PATH=../fn.mp4
MODEL_PATH=../models/version3.onnx
POSE_MODEL_PATH=../yolo11n-pose.onnx
FEATURE_SOURCE=yolo-onnx
THRESHOLD=0.5
SEQUENCE_LENGTH=41
FEATURE_DIM=153
SMOOTH_K=5
SOURCE_TYPE=video
CAMERA_INDEX=0
# Keep cpu by default; switch to cann only after replacing ONNXRUNTIME_ROOT with CANN-EP build.
ONNX_EP=cpu
ONNX_DEVICE_ID=0
SUMMARY_JSON=../artifacts/cpp_demo_onnx_orangepi_summary.json
EVENT_LOG=../artifacts/incidents.json
OUTPUT_VIDEO=../artifacts/result.mp4
MAX_FRAMES=20
LOG_EVERY=10
