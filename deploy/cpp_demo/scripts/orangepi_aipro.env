ONNXRUNTIME_ROOT=
ONNXRUNTIME_INCLUDE_DIR=/home/HwHiAiUser/onnxruntime-cann-src/include/onnxruntime/core/session
ONNXRUNTIME_LIBRARY=/home/HwHiAiUser/onnxruntime-cann-src/build/Linux/Release/libonnxruntime.so
BUILD_DIR=build-orangepi-npu
ENABLE_ONNX=ON
ENABLE_MINDSPORE=OFF

# Input Source Configuration
SOURCE_TYPE=camera
# Use the network stream URL provided
CAMERA_INDEX=0
# CAMERA_INDEX=0  # Uncomment for local USB camera

# Model Configuration
MODEL_PATH=../models/version3.onnx
POSE_MODEL_PATH=../yolo11n-pose.onnx
FEATURE_SOURCE=yolo-onnx
THRESHOLD=0.5
SEQUENCE_LENGTH=41
FEATURE_DIM=153
SMOOTH_K=5
ONNX_EP=cann
ONNX_DEVICE_ID=0

# Output Configuration
SUMMARY_JSON=../artifacts/cpp_demo_npu_summary.json
EVENT_LOG=../artifacts/incidents_npu.json
# OUTPUT_VIDEO=../artifacts/result_npu.mp4  # Disabled for continuous stream performance
MAX_FRAMES=0    # 0 = Infinite
LOG_EVERY=100
